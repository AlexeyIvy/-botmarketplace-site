node_modules/
dist/
.next/
.env
.env.local
*.log
.DS_Store
Thumbs.db

# Stray non-pnpm lockfiles. Project is fully on pnpm-lock.yaml; npm/yarn
# artifacts at any depth (typically created by accidental `npm install`
# in an app subdir) trigger Next.js workspace-root warnings and confuse
# CI. See incident 2026-05-06: apps/{api,web}/package-lock.json crept in
# and were committed.
package-lock.json
yarn.lock

# Prisma
apps/api/prisma/migrations/**/migration_lock.toml

# IDE
.idea/
.vscode/
*.swp
*.swo

# Build
*.tsbuildinfo
next-env.d.ts

# Stray TS emission inside source/test trees (dist/ is the only legitimate output).
# Guards against `tsc` runs without --noEmit or with widened `include` leaking
# .js/.js.map/.d.ts.map alongside .ts sources (see: apps/api graphCompiler
# test incident — stale tests/fixtures/graphs.js shadowed graphs.ts under
# ESM NodeNext resolution, silently dropping the MTF fixture export).
#
# Note: *.d.ts intentionally NOT listed — ambient types like
# apps/api/src/types.d.ts are legitimate hand-written source.
apps/*/src/**/*.js
apps/*/src/**/*.js.map
apps/*/src/**/*.d.ts.map
apps/*/tests/**/*.js
apps/*/tests/**/*.js.map
apps/*/tests/**/*.d.ts.map
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map
packages/*/tests/**/*.js
packages/*/tests/**/*.js.map
packages/*/tests/**/*.d.ts.map

# Claude Code secrets (never commit tokens)
.claude/secrets

# demoSmoke harness output (docs/53-T3 / 54-T1..T3 / 55-T6 sub-gate).
# Reports may include workspace IDs and run identifiers — keep them off
# git; operators excerpt summary lines into companion-docs by hand.
apps/api/scripts/.smoke-output/
