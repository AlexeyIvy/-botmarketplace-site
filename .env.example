# Database
# For production set explicit pool size to avoid exhausting Postgres max_connections.
# API + worker run as two processes; each takes `connection_limit` connections.
# Rule of thumb: (connection_limit * process_count) ≤ (postgres max_connections - admin_slots).
# Example for default Postgres (max_connections=100): connection_limit=10 → 20 total, leaves headroom.
# pool_timeout is the seconds Prisma waits for a free connection before erroring.
DATABASE_URL="postgresql://botmarket:botmarket@localhost:5432/botmarket?schema=public&connection_limit=10&pool_timeout=10"

# Redis
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-in-production"
# Worker-to-API shared secret for machine-to-machine endpoints
# (PATCH /runs/:id/state, POST /runs/:id/heartbeat, POST /runs/reconcile)
# Leave unset in dev (skips check). Must be set in production.
BOT_WORKER_SECRET="change-me-in-production"

# API
API_PORT=4000
API_HOST="0.0.0.0"

# Frontend
# Dev only: Next.js rewrites /api/* to this target.
# In production, leave empty — a reverse proxy (nginx) handles /api routing.
NEXT_PUBLIC_API_URL="http://localhost:4000"

# AI Chat Widget (Stage 17)
# Leave AI_API_KEY unset to disable the chat widget entirely.
# AI_PROVIDER: openai (default) | anthropic | groq
AI_PROVIDER=openai
# AI_API_KEY=sk-...                    # OpenAI
# AI_API_KEY=sk-ant-...                # Anthropic
# AI_API_KEY=gsk_...                   # Groq
# AI_MODEL=gpt-4o-mini                 # default for openai
# AI_MODEL=claude-haiku-4-5-20251001   # default for anthropic
# AI_MODEL=llama-3.3-70b-versatile     # default for groq
AI_MAX_TOKENS=1024
